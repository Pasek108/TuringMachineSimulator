{
  "template": [
    "tapes: 1", 
    "blank: _", 
    "comment: //", 
    "moves: <, >, -", 
    "multitape_separator: ', '", 
    "multislot_bounds: [, ]", 
    "multislot_separator: ', '", 
    "", 
    "<current_state />, <current_symbols />, <new_state />, <new_symbols />, <directions />"
  ],
  "code": [
    "// Transpiled by: https://pasek108.github.io/TuringMachineSimulator", 
    "// Example from:  https://pasek108.github.io/TuringMachineSimulator", 
    "", 
    "name: Hello, World!", 
    "init: start", 
    "accept: stop", 
    "", 
    "start, _, H1, _, -", 
    "", 
    "// print \"Hello\"", 
    "H1, _, e1, H, >", 
    "e1, _, l1, e, >", 
    "l1, _, l2, l, >", 
    "l2, _, o1, l, >", 
    "o1, _, comma, o, >", 
    "", 
    "// print \", \"", 
    "comma, _, space, ,, >", 
    "space, _, W1, _, >", 
    "", 
    "// print \"World\"", 
    "W1, _, o2, W, >", 
    "o2, _, r1, o, >", 
    "r1, _, l3, r, >", 
    "l3, _, d1, l, >", 
    "d1, _, exclamation, d, >", 
    "", 
    "// print \"!\"", 
    "exclamation, _, stop, !, >"
  ]
}
