{
  "template": [
    "tapes: 1", 
    "blank: _", 
    "comment: #", 
    "moves: L, R, S", 
    "multitape_separator: ', '", 
    "multislot_bounds: [, ]", 
    "multislot_separator: ','", 
    "", 
    "<current_state>:",
    "  <current_symbols /> -> <new_symbols />, <directions />, <new_state />"
  ],
  "code": [
    "# Transpiled by: https://pasek108.github.io/TuringMachineSimulator", 
    "# Example from:  https://rezigned.com/tur/", 
    "", 
    "# Example input: 1010",
    "", 
    "name: Even Number Checker",
    "init: start", 
    "accept: accept", 
    "", 
    "start:", 
    "  0 -> 0, R, start", 
    "  1 -> 1, R, start", 
    "  _ -> _, L, check  # Reached end, go back to last digit", 
    "check:", 
    "  0 -> 0, S, accept  # Last digit is 0 - number is even", 
    "  1 -> 1, S, reject  # Last digit is 1 - number is odd", 
    "accept:", 
    "  # Machine halts - INPUT IS EVEN"
  ]
}
