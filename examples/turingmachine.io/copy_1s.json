{
  "template": [
    "tapes: 1", 
    "blank: 0", 
    "comment: #", 
    "moves: L, R, N", 
    "multitape_separator: ', '", 
    "multislot_bounds: [, ]", 
    "multislot_separator: ','", 
    "", 
    "<current_state*>:",
    "  <current_symbols* />: {write: <new_symbols />, <directions />: <new_state />}"
  ],
  "code": [
    "# Transpiled by: https://pasek108.github.io/TuringMachineSimulator", 
    "# Example from:  https://turingmachine.io", 
    "", 
    "# Copies a string of consecutive 1s.", 
    "# Example input: '111'",
    "", 
    "name: Copy 1s", 
    "init: each", 
    "accept: H", 
    "",
    "# mark the current 1 by erasing it", 
    "each:", 
    "  0: {write: *, R: H}", 
    "  1: {write: 0, R: sep}", 
    "# skip to the separator", 
    "sep:", 
    "  0: {write: *, R: add}", 
    "  1: {write: *, R: sep}", 
    "# skip to the end of the copy and write a 1", 
    "add:", 
    "  0: {write: 1, L: sepL}", 
    "  1: {write: *, R: add}", 
    "# return to the separator", 
    "sepL:", 
    "  0: {write: *, L: next}", 
    "  1: {write: *, L: sepL}", 
    "# return to the erased 1, restore it, and then advance to the next 1", 
    "next:", 
    "  0: {write: 1, R: each}", 
    "  1: {write: *, L: next}", 
    "H:", 
    "", 
    "", 
    "# Exercises:", 
    "", 
    "# • Edit the machine to copy the string indefinitely,", 
    "#   i.e. given the input '11', produce 11011011011...", 
    "#   Hint: this can be done by modifying only one transition.", 
    "", 
    "# • Make a machine to output the endless sequence 1011011101111011111..."
  ]
}
