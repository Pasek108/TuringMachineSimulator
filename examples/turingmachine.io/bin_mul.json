{
  "template": [
    "tapes: 1", 
    "blank: ' '", 
    "comment: #", 
    "moves: L, R, N", 
    "multitape_separator: ', '", 
    "multislot_bounds: [, ]", 
    "multislot_separator: ','", 
    "", 
    "<current_state*>:",
    "  <current_symbols* />: {write: <new_symbols />, <directions />: <new_state />}"
  ],
  "code": [
    "# Transpiled by: https://pasek108.github.io/TuringMachineSimulator", 
    "# Example from:  https://turingmachine.io", 
    "", 
    "# Multiplies two binary numbers together.", 
    "", 
    "# Examples: '11x11' => '1001', '111x110' => '101010'.", 
    "# Example input: '11x101' # 3x5 = 15 (1111 in binary)",  
    "", 
    "name: Binary multiplication", 
    "init: start", 
    "accept: done", 
    "",
    "# Prefix the input with a '+', and go to the rightmost digit.", 
    "start:", 
    "  [0,1]: {write: *, L: init}", 
    "init:", 
    "  ' ': {write: +, R: right}", 
    "right:", 
    "  [0,1,x]: {write: *, R: right}", 
    "  ' ': {write: *, L: readB}", 
    "", 
    "# Read and erase the last digit of the multiplier.", 
    "# If it's 1, add the current multiplicand.", 
    "# In any case, double the multiplicand afterwards.", 
    "readB:", 
    "  0: {write: ' ', L: doubleL}", 
    "  1: {write: ' ', L: addA}", 
    "addA:", 
    "  [0,1]: {write: *, L: addA}", 
    "  x: {write: *, L: read} # enter adder", 
    "# Double the multiplicand by appending a 0.", 
    "doubleL:", 
    "  [0,1]: {write: *, L: doubleL}", 
    "  x: {write: 0, R: shift}", 
    "double: # return from adder", 
    "  [0,1,+]: {write: *, R: double}", 
    "  x: {write: 0, R: shift}", 
    "# Make room by shifting the multiplier right 1 cell.", 
    "shift:", 
    "  0: {write: x, R: shift0}", 
    "  1: {write: x, R: shift1}", 
    "  ' ': {write: *, L: tidy} # base case: multiplier = 0", 
    "shift0:", 
    "  0: {write: *, R: shift0}", 
    "  1: {write: 0, R: shift1}", 
    "  ' ': {write: 0, R: right}", 
    "shift1:", 
    "  0: {write: 1, R: shift0}", 
    "  1: {write: *, R: shift1}", 
    "  ' ': {write: 1, R: right}", 
    "", 
    "tidy:", 
    "  [0,1]: {write: ' ', L: tidy}", 
    "  +: {write: ' ', L: done}",  
    "", 
    "# This is the 'binary addition' machine almost verbatim.", 
    "# It's adjusted to keep the '+'", 
    "# and to lead to another state instead of halting.", 
    "read:", 
    "  0: {write: c, L: have0}", 
    "  1: {write: c, L: have1}", 
    "  +: {write: *, L: rewrite} # keep the +", 
    "have0:",
    "  [0,1]: {write: *, L: have0}",
    "  +: {write: *, L: add0}", 
    "have1:",
    "  [0,1]: {write: *, L: have1}",
    "  +: {write: *, L: add1}", 
    "add0:", 
    "  [0,' ']: {write: O, R: back0}", 
    "  1: {write: I, R: back0}", 
    "  [O,I]: {write: *, L: add0}", 
    "add1:", 
    "  [0,' ']: {write: I, R: back1}", 
    "  1: {write: O, L: carry}", 
    "  [O,I]: {write: *, L: add1}", 
    "carry:", 
    "  [0,' ']: {write: 1, R: back1}", 
    "  1: {write: 0, L: carry}", 
    "back0:", 
    "  [0,1,O,I,+]: {write: *, R: back0}", 
    "  c: {write: 0, L: read}", 
    "back1:", 
    "  [0,1,O,I,+]: {write: *, R: back1}", 
    "  c: {write: 1, L: read}", 
    "rewrite:", 
    "  O: {write: 0, L: rewrite}", 
    "  I: {write: 1, L: rewrite}", 
    "  [0,1]: {write: *, L: rewrite}", 
    "  ' ': {write: *, R: double} # when done, go to the 'double' state", 
    "done:",
    "", 
    "", 
    "# Remark:", 
    "# We can view the machine as expressing a recursive function:", 
    "", 
    "#   multiply(a, b) = mult(0, a, b)", 
    "", 
    "#   mult(acc, a, 0     ) = acc", 
    "#   mult(acc, a, 2k + 0) = mult(acc    , 2a, k)   where k ≠ 0", 
    "#   mult(acc, a, 2k + 1) = mult(acc + a, 2a, k)", 
    "", 
    "# where a, b, and k are natural numbers.", 
    "", 
    "# Each reduction maintains the invariant", 
    "#   mult(acc, a, b) = acc + a * b", 
    "# Note that mult's third argument (b) is always decreasing,", 
    "# so mult is guaranteed to halt.", 
    "# Eventually b reaches 0 and the result is simply the accumulator."
  ]
}
