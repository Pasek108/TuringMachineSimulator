{
  "template": [
    "tapes: 1", 
    "blank: ' '", 
    "comment: #", 
    "moves: L, R, N", 
    "multitape_separator: ', '", 
    "multislot_bounds: [, ]", 
    "multislot_separator: ','", 
    "", 
    "<current_state*>:",
    "  <current_symbols* />: {write: <new_symbols />, <directions />: <new_state />}"
  ],
  "code": [
    "# Transpiled by: https://pasek108.github.io/TuringMachineSimulator", 
    "# Example from:  https://turingmachine.io", 
    "", 
    "# Accepts palindromes made of the symbols 'a' and 'b'", 
    "# Example input: 'abba' # try a, ab, bb, babab", 
    "", 
    "name: Palindrome", 
    "init: start", 
    "accept: accept", 
    "", 
    "# A palindrome is either the empty string, a single symbol,", 
    "# or a (shorter) palindrome with the same symbol added to both ends.", 
    "start:", 
    "  a: {write: ' ', R: haveA}", 
    "  b: {write: ' ', R: haveB}", 
    "  ' ': {write: *, R: accept} # empty string", 
    "haveA:", 
    "  [a,b]: {write: *, R: haveA}", 
    "  ' ': {write: *, L: matchA}", 
    "haveB:", 
    "  [a,b]: {write: *, R: haveB}", 
    "  ' ': {write: *, L: matchB}", 
    "matchA:", 
    "  a: {write: ' ', L: back} # same symbol at both ends", 
    "  b: {write: *, R: reject}", 
    "  ' ': {write: *, R: accept} # single symbol", 
    "matchB:", 
    "  a: {write: *, R: reject}", 
    "  b: {write: ' ', L: back} # same symbol at both ends", 
    "  ' ': {write: *, R: accept} # single symbol", 
    "back:", 
    "  [a,b]: {write: *, L: back}", 
    "  ' ': {write: *, R: start}", 
    "accept:",  
    "", 
    "", 
    "# Exercise:", 
    "", 
    "# • Modify the machine to include 'c' in the symbol alphabet,", 
    "#   so it also works for strings like 'cabbac'."
  ]
}
