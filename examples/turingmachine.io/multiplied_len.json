{
  "template": [
    "tapes: 1", 
    "blank: ' '", 
    "comment: #", 
    "moves: L, R, N", 
    "multitape_separator: ', '", 
    "multislot_bounds: [, ]", 
    "multislot_separator: ','", 
    "", 
    "<current_state*>:",
    "  <current_symbols* />: {write: <new_symbols />, <directions />: <new_state />}"
  ],
  "code": [
    "# Transpiled by: https://pasek108.github.io/TuringMachineSimulator", 
    "# Example from:  https://turingmachine.io", 
    "", 
    "# Decides the language { a^(i)b^(j)c^(k) | i*j = k and i,j,k ≥ 1 }.", 
    "# (a's followed by b's then c's,", 
    "# where the number of a's multiplied by the number of b's", 
    "# equals the number of c's.)", 
    "# Example input: aabbbcccccc # try abc, b, aabcbc, aabcc, aabbbbcccccccc", 
    "", 
    "name: Multiplied lengths", 
    "init: start", 
    "accept: accept", 
    "",
    "# Check for the form a^(i)b^(j)c^(k) where i,j,k ≥ 1.", 
    "start:",
    "  a: {write: *, R: a}", 
    "a:",
    "  a: {write: *, R: a}",
    "  b: {write: *, R: b}", 
    "b:",
    "  b: {write: *, R: b}",
    "  c: {write: *, R: c}", 
    "c:",
    "  c: {write: *, R: c}",
    "  ' ': {write: *, L: left}", 
    "left:", 
    "  [a,b,c]: {write: *, L: left}", 
    "  ' ': {write: *, R: eachA}", 
    "# Then check that i*j = k.", 
    "#   The approach is two nested loops:", 
    "#   For each 'a':", 
    "#     For each 'b':", 
    "#       Mark one 'c'", 
    "#   At the end, check that all c's are marked.", 
    "eachA:", 
    "  a: {write: ' ', R: eachB}", 
    "  b: {write: *, R: scan}", 
    "eachB:", 
    "  a: {write: *, R: eachB}", 
    "  b: {write: B, R: markC}", 
    "  C: {write: *, L: nextA}", 
    "markC:", 
    "  [b,C]: {write: *, R: markC}", 
    "  c: {write: C, L: nextB}", 
    "nextB:", 
    "  [b,C]: {write: *, L: nextB}", 
    "  B: {write: *, R: eachB}", 
    "nextA:", 
    "  a: {write: *, L: nextA}", 
    "  B: {write: b, L: nextA}", 
    "  ' ': {write: *, R: eachA}", 
    "", 
    "scan:", 
    "  [b,C]: {write: *, R: scan}", 
    "  ' ': {write: *, R: accept}", 
    "accept:"
  ]
}
