{
  "template": [
    "tapes: 1", 
    "blank: ' '", 
    "comment: #", 
    "moves: L, R, N", 
    "multitape_separator: ', '", 
    "multislot_bounds: [, ]", 
    "multislot_separator: ','", 
    "", 
    "<current_state*>:",
    "  <current_symbols* />: {write: <new_symbols />, <directions />: <new_state />}"
  ],
  "code": [
    "# Transpiled by: https://pasek108.github.io/TuringMachineSimulator", 
    "# Example from:  https://turingmachine.io", 
    "", 
    "# Multiplies together two unary numbers separated by a 'x'.", 
    "# (Unary is like tallying. Here '||x|||' means 2 times 3.)", 
    "# Example input: '||x|||' # try 'x', '|x|||', '||||x||'", 
    "", 
    "name: Unary multiplication", 
    "init: eachA", 
    "accept: done", 
    "", 
    "# The idea:", 
    "#   multiply(0, b) = 0", 
    "#   multiply(a, b) = b + multiply(a-1, b)   when a > 0", 
    "", 
    "# For each 1 in a, add a copy of b.", 
    "eachA:", 
    "  |: {write: ' ', R: toB}  # Inductive case: a > 0.", 
    "  x: {write: *, R: skip}             # Base case:      a = 0.", 
    "toB:", 
    "  |: {write: *, R: toB}", 
    "  x: {write: *, R: eachB} # enter copier", 
    "nextA: # return from copier", 
    "  ' ': {write: |, R: eachA}", 
    "  [|,x]: {write: *, L: nextA}", 
    "", 
    "skip:", 
    "  |: {write: *, R: skip}", 
    "  ' ': {write: *, R: done}", 
    "", 
    "# This is the 'copy 1s' machine, with ' ' as 0 and | as 1.", 
    "eachB:", 
    "  ' ': {write: *, L: nextA}", 
    "  |: {write: ' ', R: sep}", 
    "sep:", 
    "  ' ': {write: *, R: add}", 
    "  |: {write: *, R: sep}", 
    "add:", 
    "  ' ': {write: |, L: sepL}", 
    "  |: {write: *, R: add}", 
    "sepL:", 
    "  ' ': {write: *, L: nextB}", 
    "  |: {write: *, L: sepL}", 
    "nextB:", 
    "  ' ': {write: |, R: eachB}", 
    "  |: {write: *, L: nextB}",
    "done:"
  ]
}
